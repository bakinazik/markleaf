{
  "manifest_version": 3,
  "name": "Markleaf: Bookmark Manager",
  "description": "Bookmark manager.",
  "version": "1.1.1",
  "default_locale": "en",
  "permissions": [
    "bookmarks",
    "tabs",
    "storage",
    "activeTab",
    "favicon",
    "contextMenus"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "web_accessible_resources": [
    {
      "resources": [
        "terms-of-use.txt",
        "privacy-policy.txt",
        "license.txt"
      ],
      "matches": ["<all_urls>"]
    }
  ],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/16.png",
      "48": "icons/48.png",
      "128": "icons/128.png"
    }
  },
  "icons": {
      "16": "icons/16.png",
      "48": "icons/48.png",
      "128": "icons/128.png"
  }
}