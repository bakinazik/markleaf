{
  "manifest_version": 3,
  "name": "Markleaf: Bookmark Manager",
  "description": "Bookmark manager.",
  "version": "1.2.1",
  "default_locale": "en",
  "permissions": [
    "bookmarks",
    "tabs",
    "storage",
    "activeTab",
    "favicon"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/16.png",
      "48": "icons/48.png",
      "128": "icons/128.png"
    }
  },
  "icons": {
      "16": "icons/16.png",
      "48": "icons/48.png",
      "128": "icons/128.png"
  }
}